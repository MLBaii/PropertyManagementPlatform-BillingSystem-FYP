# Copy this file to .env and set the base URL for your setup.
# EXPO_PUBLIC_ vars are inlined into the JS bundle at build/start time —
# restart `npx expo start` after changing this value.
#
# Pick ONE based on how you're running the app relative to the backend (`dotnet run` in ../backend):
#   Android emulator : http://10.0.2.2:5112/api        (10.0.2.2 = the emulator's alias for your dev machine's localhost)
#   iOS simulator    : http://localhost:5112/api         (simulator shares the host machine's network stack)
#   Physical device  : http://<dev-machine-LAN-IP>:5112/api   (phone and dev machine must be on the same Wi-Fi;
#                                                               find your IP with `ipconfig` on Windows)
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5112/api
