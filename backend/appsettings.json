{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=db.<project-ref>.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=[YOUR-PASSWORD];SSL Mode=Require;Trust Server Certificate=true"
  },
  "Jwt": {
    "Key": "[YOUR-JWT-SIGNING-KEY]",
    "Issuer": "PropertyBill.Api",
    "Audience": "PropertyBill.Client",
    "ExpiryMinutes": 60
  },
  "Supabase": {
    "Url": "https://<project-ref>.supabase.co",
    "ServiceRoleKey": "[YOUR-SUPABASE-SERVICE-ROLE-KEY]",
    "StorageBucket": "payment-proofs"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableTls": true,
    "Username": "[YOUR-SMTP-USER]",
    "Password": "[YOUR-SMTP-PASSWORD]",
    "FromEmail": "[YOUR-SMTP-USER]",
    "FromName": "PropertyBill"
  }
}